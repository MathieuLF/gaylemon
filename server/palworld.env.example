PALWORLD_ROOT=/srv/storage/steam/servers/palworld
PALWORLD_GAME_DIR=/srv/storage/steam/servers/palworld/game
PALWORLD_CONFIG_DIR=/srv/storage/steam/servers/palworld/config
PALWORLD_BACKUP_DIR=/srv/storage/steam/servers/palworld/backups
PALWORLD_LOG_DIR=/srv/storage/steam/servers/palworld/logs

PALWORLD_PORT=8211
PALWORLD_MAX_PLAYERS=12
PALWORLD_ARGS="-port=8211 -players=12 -logformat=text"

# Secrets utilisés uniquement lors de la génération de PalWorldSettings.ini.
# Le vrai fichier /etc/palworld/palworld.env doit rester hors Git et en mode 0640.
SERVER_PASSWORD=
ADMIN_PASSWORD=

# Maintenance automatique: report si des joueurs sont présents, nouvelle
# tentative après 30 minutes et annonces à 5 min, 1 min et 30 s.
PALWORLD_UPDATE_DEFER_IF_PLAYERS=true
PALWORLD_UPDATE_RETRY_DELAY_SECONDS=1800
PALWORLD_UPDATE_COUNTDOWN_STEPS="300 60 30"
PALWORLD_UPDATE_API_WAIT_ATTEMPTS=60
PALWORLD_UPDATE_API_WAIT_SECONDS=2

PALWORLD_BACKUP_RETENTION_DAYS=14
PALWORLD_BACKUP_SAVE_WAIT_SECONDS=5
PALWORLD_REST_BASE_URL=http://127.0.0.1:8212/v1/api

CF_API_TOKEN=
CF_ZONE_ID=
CF_RECORD_NAME=palworld.example.com
CF_RECORD_TYPE=A
CF_RECORD_TTL=1
CF_RECORD_PROXIED=false
