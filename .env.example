# Configuration locale Gaylémon. Copier ce fichier vers .env.
# Ne jamais ajouter de mot de passe, jeton Cloudflare, clé API réelle ou URL Push Kuma ici.

# Connexion au serveur Ubuntu
GAYLEMON_SSH_ALIAS=palworld
GAYLEMON_SSH_DIR=
GAYLEMON_SERVER_LAN_IP=192.168.1.50
GAYLEMON_REMOTE_PROJECT_ROOT=/home/palworld/Gaylemon
GAYLEMON_REMOTE_PROJECT_USER=palworld
GAYLEMON_REMOTE_STEAM_ROOT=/srv/storage/steam

# Microsite Docker local
GAYLEMON_MICROSITE_PORT=8787
GAYLEMON_MICROSITE_PUBLIC_URL=http://127.0.0.1:8787/
GAYLEMON_METRIC_INTERVAL_SECONDS=60
GAYLEMON_METRIC_UPDATE_TIMEOUT_SECONDS=120
GAYLEMON_DOCKER_MICROSITE_CONTAINER=gaylemon-microsite

# Tunnel REST Palworld local
GAYLEMON_API_TUNNEL_MODE=docker
GAYLEMON_API_LOCAL_PORT=8212
GAYLEMON_API_REMOTE_PORT=8212

# Intégrations externes en lecture seule
GAYLEMON_UPTIME_KUMA_BASE_URL=http://127.0.0.1:3001
GAYLEMON_UPTIME_KUMA_STATUS_SLUG=palworld
GAYLEMON_UPTIME_KUMA_PUBLIC_URL=
GAYLEMON_UPTIME_KUMA_API_KEY=
GAYLEMON_UPTIME_KUMA_CONTAINER=uptime-kuma
GAYLEMON_UPTIME_KUMA_DB_PATH=/app/data/kuma.db
GAYLEMON_UPTIME_KUMA_MONITOR_ID=1
GAYLEMON_UPTIME_HISTORY_DAYS=90
GAYLEMON_RECOVERY_STALE_SECONDS=90
GAYLEMON_CLOUDFLARED_CONTAINER_PATTERN=cloudflared

# Accès public au jeu et communauté
GAYLEMON_GAME_HOST=palworld.example.com
GAYLEMON_GAME_PORT=8211
GAYLEMON_DISCORD_URL=https://discord.gg/EXEMPLE
GAYLEMON_GITHUB_URL=https://github.com/UTILISATEUR/gaylemon
GAYLEMON_GA4_ID=

# Dépendance PalworldSaveTools
GAYLEMON_SAVE_TOOLS_UPSTREAM=deafdudecomputers/PalworldSaveTools
GAYLEMON_SAVE_TOOLS_FORK=UTILISATEUR/PalworldSaveTools

# Tâches Windows
GAYLEMON_STARTUP_TASK_NAME=Gaylemon Ops Local Services
GAYLEMON_SAVE_TOOLS_TASK_NAME=Gaylemon PalworldSaveTools Maintenance
